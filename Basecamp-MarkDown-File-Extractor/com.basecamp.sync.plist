<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.basecamp.sync</string>

    <key>ProgramArguments</key>
    <array>
        <string>/bin/zsh</string>
        <string>/Users/mirakozoglu/Documents/Antigravity/Basecamp-MarkDown-File-Extractor/run_sync.sh</string>
    </array>

    <!-- Run every day at 08:00 AM -->
    <key>StartCalendarInterval</key>
    <dict>
        <key>Hour</key>
        <integer>8</integer>
        <key>Minute</key>
        <integer>0</integer>
    </dict>

    <key>StandardOutPath</key>
    <string>/Users/mirakozoglu/Documents/Antigravity/Basecamp-MarkDown-File-Extractor/sync_stdout.log</string>

    <key>StandardErrorPath</key>
    <string>/Users/mirakozoglu/Documents/Antigravity/Basecamp-MarkDown-File-Extractor/sync_stderr.log</string>

    <!-- Run when conditions are met even if the Mac was asleep at 8am -->
    <key>RunAtLoad</key>
    <false/>
</dict>
</plist>
